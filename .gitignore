# Build artifacts
build/
release/
*.o
*.elf
*.img
*.bin
*.map
*.lst
*.dis
*.tar.gz

# Cross-compiled package binaries are deliverables, not throwaway
# build artifacts -- ship them so 'pkg fetch' has something to serve.
!tools/repo/packages/**/*.elf

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local docs / specs / notes — README.md is the only tracked Markdown
docs/
*.md
!README.md
